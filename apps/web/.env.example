# Supabase Postgres (Transaction pooler — dùng cho app runtime)
# Dashboard → Project Settings → Database → Connection string → URI (Mode: Transaction)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres (Direct — dùng cho Prisma migrate / db push)
# Dashboard → Connection string → URI (Mode: Session) hoặc Direct connection port 5432
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Public registration is disabled by default
ALLOW_PUBLIC_REGISTER="false"
