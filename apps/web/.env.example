# Supabase Postgres (Transaction pooler — runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Supabase Postgres (Session pooler — Prisma migrate / db push)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth — generate with: openssl rand -base64 32 (min 32 chars, no placeholders)
AUTH_SECRET=""
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Seed admin (required for prisma db seed) — min 12 chars, not a common password
SEED_ADMIN_EMAIL="admin@sergioagency.com"
SEED_ADMIN_PASSWORD=""

# Public registration is bootstrap-only (first user). Keep false.
ALLOW_PUBLIC_REGISTER="false"

# Contact form notifications (default: namdoan.ka@gmail.com)
CONTACT_TO_EMAIL="namdoan.ka@gmail.com"
# Optional Resend (recommended). Without it, FormSubmit fallback is used.
# RESEND_API_KEY=""
# CONTACT_FROM_EMAIL="Sergio Agency <noreply@yourdomain.com>"

# Optional: Vercel Blob for production image uploads
# BLOB_READ_WRITE_TOKEN=""
