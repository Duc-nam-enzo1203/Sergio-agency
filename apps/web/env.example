# Copy to .env / Vercel — never commit real secrets

# Supabase Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth (openssl rand -base64 32)
AUTH_SECRET=""
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Seed
SEED_ADMIN_EMAIL="namdoan.ka@gmail.com"
SEED_ADMIN_PASSWORD=""

ALLOW_PUBLIC_REGISTER="false"
CONTACT_TO_EMAIL="namdoan.ka@gmail.com"

# Optional: Resend
# RESEND_API_KEY=""
# CONTACT_FROM_EMAIL="Sergio Agency <noreply@yourdomain.com>"

# Optional: Vercel Blob
# BLOB_READ_WRITE_TOKEN=""

# Optional: Upstash Redis (distributed rate limit)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: canonical site URL for SEO/AEO (sitemap, JSON-LD, Open Graph)
# NEXT_PUBLIC_SITE_URL="https://sergio-agency.vercel.app"

# Optional: Sentry
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
